<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto">

    <ContentPage.ToolbarItems>
        <!-- Botão "Salvar" que executa o método ToolbarItem_Clicked quando clicado -->
        <ToolbarItem 
            Text="Salvar"
   Clicked="ToolbarItem_Clicked"/>

    </ContentPage.ToolbarItems>
    <!-- Layout vertical que organiza os elementos da tela -->
    <!-- Spacing define o espaço entre os elementos e Padding a margem interna -->
    <VerticalStackLayout Spacing="10" Padding="10">
        <!-- Label's é o texto indicando o campo de descrição, a quantidade e o preço unitário -->
        <!-- Entry's são os campos de entrada para o usuário digitar a descrição do produto, 
        a quantidade em forma numerica, e o preço em forma numérica também -->
        <Label Text="Descrição:"/>
        <Entry x:Name="txt_descricao"/>
        
        <Label Text="Quantidade:"/>
        <Entry x:Name="txt_quantidade" Keyboard="Numeric"/>

        <Label Text="Preço Unitário:"/>
        <Entry x:Name="txt_preco" Keyboard="Numeric"/>

    </VerticalStackLayout>
</ContentPage>